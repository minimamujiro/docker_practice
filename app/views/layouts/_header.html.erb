<header class="navbar navbar-expand-lg navbar-dark bg-dark fixed-top">
  <div class="container">
    <%= link_to "sample app", root_path, id: "logo", class: "navbar-brand" %>
    <nav class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto">
        <li><%= link_to "Home", root_path, class: "nav-link" %></li>
        <li><%= link_to "Help", help_path, class: "nav-link" %></li>
        <% if logged_in? %>
          <li><%= link_to "Users", users_path, class: "nav-link"%></li>
          <li class="dropdown">
            <a href="#" id="account" class="dropdown-toggle nav-link" data-bs-toggle="dropdown" aria-expanded="false">
              Account <b class="caret"></b>
            </a>
            <ul id="dropdown-menu" class="dropdown-menu">
              <li><%= link_to 'Profile', current_user %></li>
              <li><%= link_to 'Settings', '#'%></li>
              <li class="divider"></li>
              <li>
                <%= link_to 'Log out', logout_path, data: { 'turbo-method': :delete } %>
              </li>
            </ul>
          </li>
        <% else %>
          <li><%= link_to "Log in", login_path, class: "nav-link" %></li>
        <% end %>
      </ul>
    </nav>
  </div>
</header>